# Backend
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=300
LOG_LEVEL=INFO

# Frontend/hosting. BACKEND_URL is used by Next.js rewrites in deployed frontend containers/Vercel.
BACKEND_URL=http://localhost:8000
PORT=8000

# Local dev uses SQLite by default. Set DATABASE_URL for Supabase/Neon/DigitalOcean Postgres.
# Supabase Shared/Session Pooler format:
# DATABASE_URL=postgresql+psycopg://USER:URL_ENCODED_PASSWORD@HOST:5432/postgres?sslmode=require

# Or set Supabase DB components; the backend builds DATABASE_URL safely.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require

# Supabase Shared/Session Pooler. Use this on IPv4 networks/free Supabase.
SUPABASE_POOLER_HOST=
SUPABASE_POOLER_PORT=
SUPABASE_POOLER_USER=

# Supabase project API keys, if using Supabase services directly.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Optional free-model reranking
OPENROUTER_API_KEY=
OPENROUTER_MODEL=inclusionai/ring-2.6-1t:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
