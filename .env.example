# Backend
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=300
LOG_LEVEL=INFO
# Set APP_ENV=production on deployed backends. Production requires Firebase credentials.
APP_ENV=development

# Frontend/hosting. BACKEND_URL is used by Next.js rewrites in deployed frontend containers/Vercel.
BACKEND_URL=http://localhost:8000
PORT=8000

# Database: Firebase Firestore.
# Provide ONE of the following credential sources:
# 1) Inline service-account JSON (recommended for DigitalOcean/Vercel env config):
FIREBASE_SERVICE_ACCOUNT_JSON=
# 2) Path to a service-account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
# Optional explicit project id (required with the emulator):
FIREBASE_PROJECT_ID=
# Local emulator (optional): FIRESTORE_EMULATOR_HOST=localhost:8080
# Local dev without credentials uses an in-memory store (data resets on restart).
# Force a backend explicitly with PROFMATCH_DB=memory or PROFMATCH_DB=firestore.

# Optional free-model reranking
OPENROUTER_API_KEY=
OPENROUTER_MODEL=inclusionai/ring-2.6-1t:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
