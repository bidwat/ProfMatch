# Backend
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=300
LOG_LEVEL=INFO

# Local dev uses SQLite by default. Set DATABASE_URL for Supabase/Neon Postgres.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Or set Supabase DB components; migration script builds DATABASE_URL safely.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require

# If your direct Supabase host says "Not IPv4 compatible", use Session Pooler.
SUPABASE_POOLER_HOST=
SUPABASE_POOLER_PORT=5432
SUPABASE_POOLER_USER=

# Supabase project API keys, if using Supabase services directly.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Optional free-model reranking
OPENROUTER_API_KEY=
OPENROUTER_MODEL=inclusionai/ring-2.6-1t:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
